      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.usedelia.app"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "iosDisplayInForeground": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "69b85eef-8ab3-459b-8211-7399de949723"
      }
    }
  }
}
